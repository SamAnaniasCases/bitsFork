# Backend Environment Variables - TEMPLATE
# Copy this file to .env and fill in your own values.
# Never commit the actual .env file.

# Server
NODE_ENV=development
PORT=3001

# Database
# LOCAL: point to your local PostgreSQL instance
# DOCKER: values are overridden by docker-compose.yml
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=db_bits
DB_USER=postgres
DB_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
DATABASE_URL=postgresql://postgres:REPLACE_WITH_STRONG_PASSWORD@127.0.0.1:5432/db_bits

# JWT Secrets
# Generate with: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET

# ZKTeco Device
ZK_HOST=192.168.0.201
ZK_PORT=4370

# CORS — URL of the frontend that the backend will accept requests from
# LOCAL:  http://localhost:3010
# DOCKER: set via docker-compose.yml (e.g. http://10.10.0.98:3010 for a server)
FRONTEND_URL=http://localhost:3000
